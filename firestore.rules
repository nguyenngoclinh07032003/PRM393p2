rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return userExists() ? userDoc().data.role : 'customer';
    }

    function isAdmin() {
      return isSignedIn() && userRole() == 'admin';
    }

    function isSeller() {
      return isSignedIn() && userRole() == 'seller';
    }

    function isActiveUser() {
      return isSignedIn()
        && userExists()
        && userDoc().data.get('status', 'active') != 'inactive';
    }

    // --- Users ---
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.role == 'customer'
        && request.resource.data.get('status', 'active') == 'active';
      allow update: if isSignedIn() && (
        (request.auth.uid == userId
          && request.resource.data.role == resource.data.role)
        || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // --- Products ---
    match /products/{productId} {
      allow read: if isSignedIn();
      allow create: if isActiveUser() && (
        isAdmin()
        || (isSeller() && request.resource.data.sellerId == request.auth.uid)
      );
      allow update, delete: if isActiveUser() && (
        isAdmin()
        || (isSeller() && resource.data.sellerId == request.auth.uid)
      );
    }

    // --- Carts (chỉ chủ giỏ) ---
    match /carts/{cartId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isActiveUser()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isActiveUser()
        && resource.data.userId == request.auth.uid;
    }

    // --- Orders ---
    match /orders/{orderId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid
        || resource.data.sellerId == request.auth.uid
        || isAdmin()
      );
      allow create: if isActiveUser()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isActiveUser() && (
        isAdmin()
        || resource.data.sellerId == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    match /order_items/{itemId} {
      allow read: if isSignedIn();
      allow create: if isActiveUser();
      allow update, delete: if isAdmin();
    }

    // --- Flash sales (admin cấu hình) ---
    match /flash_sales/{saleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Group buy ---
    match /group_buys/{groupBuyId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || isSeller();
      allow update: if isActiveUser();
      allow delete: if isAdmin();
    }

    // --- Rebuy stats ---
    match /rebuy_stats/{statId} {
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow create: if isActiveUser()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isActiveUser()
        && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // --- Discounts / notifications (nếu dùng) ---
    match /discounts/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /notifications/{id} {
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow write: if isAdmin();
    }
  }
}
